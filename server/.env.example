# .env.example
# Node.js Server specific environment variables

PORT=3000
NODE_ENV=development

# Traffic & Maps (Add your Google Maps Key for Distance Matrix)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Advisories (RSS feed URL for Himachal Police / BRO if available)
BRO_RSS_FEED_URL=https://example.com/bro-rss
